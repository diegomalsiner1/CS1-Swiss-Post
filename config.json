{
  "run": {
    "use_case": "Peak_Shaving",
    "timestep_minutes": 15,
    "horizon_days": 365,
    "solver": "CBC"
  },

  "economics": {
    "discount_rate": 0.06,
    "lifetime_years": 15,
    "capex_chf_per_kwh": 450
  },

  "pv": {
    "max_capacity_kw": 10000
  },

  "battery": {
    "max_capacity_kwh": 1000000,
    "max_inflow_kw": 10000,
    "max_outflow_kw": 10000,
    "eta_charge": 0.9,
    "eta_discharge": 0.95,
    "eta_self_discharge_per_step": 0.01,
    "max_charging_c_rate": 1.0,
    "max_discharging_c_rate": 1.0,
    "dod_max": 0.9
  },

  "inputs": {
    "excel_path": "data/inputs.xlsx",
    "load_sheet": "load",
    "pv_sheet": "pv",
    "tariff_sheet": "tariff"
  }
}
